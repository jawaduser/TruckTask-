<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:tracktask.ViewModels"
    x:Class="tracktask.View.AdminView.AddUsers"
    Title="Add Users"
    BackgroundColor="#F4F6F8">

    <ContentPage.BindingContext>
        <vm:AdminViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout
            Padding="25"
            Spacing="20"
            HorizontalOptions="Center"
            WidthRequest="520">

            <Label Text="Add / Edit User"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#2C3E50"
                   HorizontalOptions="Center" />

            <Label Text="Create or update admin and driver accounts"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,-10,0,10" />

            <Frame CornerRadius="20"
                   Padding="25"
                   BackgroundColor="White"
                   HasShadow="True"
                   WidthRequest="520">

                <VerticalStackLayout Spacing="15">

                    <Entry Placeholder="Full Name"
                           Text="{Binding Name}"
                           HeightRequest="50"
                           TextColor="Black"
                           BackgroundColor="#F7F9FB" />

                    <Entry Placeholder="Email"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           HeightRequest="50"
                           TextColor="Black"
                           BackgroundColor="#F7F9FB" />

                    <Entry Placeholder="Password"
                           Text="{Binding Password}"
                           IsPassword="True"
                           HeightRequest="50"
                           TextColor="Black"
                           BackgroundColor="#F7F9FB" />

                    <Label Text="Role"
                           TextColor="Gray"
                           FontSize="14" />

                    <Picker ItemsSource="{Binding Roles}"
                            SelectedItem="{Binding SelectedRole}"
                            Title="Select Role"
                            HeightRequest="60"
                            WidthRequest="470"
                            BackgroundColor="#F7F9FB"
                            TextColor="Black"
                            TitleColor="Gray"
                            HorizontalOptions="Center" />

                    <Button Text="Save User"
                            Command="{Binding SaveUserCommand}"
                            BackgroundColor="#4A90E2"
                            TextColor="White"
                            HeightRequest="55"
                            CornerRadius="15" />



                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="#4A90E2" />

                </VerticalStackLayout>
            </Frame>

            <Label Text="Existing Users"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#2C3E50"
                   Margin="0,15,0,0" />

            <CollectionView ItemsSource="{Binding Users}"
                            HeightRequest="400"
                            WidthRequest="520">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,6"
                               Padding="15"
                               CornerRadius="16"
                               BackgroundColor="White"
                               HasShadow="True">

                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnSpacing="10">

                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#2C3E50" />

                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Text="{Binding Email}"
                                       FontSize="14"
                                       TextColor="Gray" />

                                <Label Grid.Row="2"
                                       Grid.Column="0"
                                       Text="{Binding UserId, StringFormat='ID: {0}'}"
                                       FontSize="12"
                                       TextColor="#999999" />

                                <Frame Grid.Row="0"
                                       Grid.RowSpan="3"
                                       Grid.Column="1"
                                       Padding="10,5"
                                       CornerRadius="12"
                                       BackgroundColor="#EAF2FF"
                                       HasShadow="False"
                                       VerticalOptions="Center">

                                    <Label Text="{Binding Role}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#4A90E2" />

                                </Frame>

                                <HorizontalStackLayout Grid.Row="3"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       Spacing="10"
                                                       Margin="0,10,0,0">

                                    <Button Text="Edit"
                                            Clicked="OnEditClicked"
                                            BackgroundColor="#3498DB"
                                            TextColor="White"
                                            HeightRequest="45"
                                            WidthRequest="220"
                                            CornerRadius="12" />

                                    <Button Text="Delete"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminViewModel}}, Path=DeleteUserCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#E74C3C"
                                            TextColor="White"
                                            HeightRequest="45"
                                            WidthRequest="220"
                                            CornerRadius="12" />

                                </HorizontalStackLayout>

                            </Grid>

                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>