<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:tracktask.ViewModels"
    x:Class="tracktask.View.TripPage"
    Title="Trips"
    BackgroundColor="#F4F6F8">

    <ContentPage.BindingContext>
        <vm:TripViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout
            Padding="25"
            Spacing="20"
            HorizontalOptions="Center"
            WidthRequest="520">

            <Label Text="Trip Management"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#2C3E50"
                   HorizontalOptions="Center" />

            <Label Text="Create and manage trips"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,-10,0,10" />

            <Frame CornerRadius="20"
                   Padding="25"
                   BackgroundColor="White"
                   HasShadow="True"
                   WidthRequest="520">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Select User"
                           TextColor="Gray"
                           FontSize="14" />

                    <Picker ItemsSource="{Binding Users}"
                            SelectedItem="{Binding SelectedUser}"
                            ItemDisplayBinding="{Binding Name}"
                            Title="Choose user"
                            HeightRequest="60"
                            WidthRequest="470"
                            BackgroundColor="#F7F9FB"
                            TextColor="Black"
                            TitleColor="Gray" />

                    <Label Text="Select Track"
                           TextColor="Gray"
                           FontSize="14" />

                    <Picker ItemsSource="{Binding Tracks}"
                            SelectedItem="{Binding SelectedTrack}"
                            ItemDisplayBinding="{Binding Modules}"
                            Title="Choose track"
                            HeightRequest="60"
                            WidthRequest="470"
                            BackgroundColor="#F7F9FB"
                            TextColor="Black"
                            TitleColor="Gray" />

                    <Entry Placeholder="Product"
                           Text="{Binding Product}"
                           HeightRequest="50"
                           TextColor="Black"
                           BackgroundColor="#F7F9FB" />

                    <Entry Placeholder="Location"
                           Text="{Binding Location}"
                           HeightRequest="50"
                           TextColor="Black"
                           BackgroundColor="#F7F9FB" />

                    <DatePicker Date="{Binding Date}"
                                HeightRequest="50"
                                BackgroundColor="#F7F9FB"
                                TextColor="Black" />

                    <Button Text="Save Trip"
                            Command="{Binding SaveTripCommand}"
                            BackgroundColor="#4A90E2"
                            TextColor="White"
                            HeightRequest="55"
                            CornerRadius="15" />

                </VerticalStackLayout>
            </Frame>

            <Label Text="Existing Trips"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#2C3E50"
                   Margin="0,15,0,0" />

            <CollectionView ItemsSource="{Binding Trips}"
                            HeightRequest="400"
                            WidthRequest="520">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,6"
                               Padding="15"
                               CornerRadius="16"
                               BackgroundColor="White"
                               HasShadow="True">

                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="10">

                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Product, StringFormat='trackload: {0}'}"
                                       FontSize="14"
                                       TextColor="Gray" />

                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Text="{Binding Location, StringFormat='Destination: {0}'}"
                                       FontSize="14"
                                       TextColor="#555555" />

                                <Label Grid.Row="2"
                                       Grid.Column="0"
                                       Text="{Binding Date, StringFormat='Date: {0:dd/MM/yyyy}'}"
                                       FontSize="14"
                                       TextColor="Gray" />

                                <Label Grid.Row="3"
                                       Grid.Column="0"
                                       Text="{Binding UserName, StringFormat='Driver: {0}'}"
                                       FontSize="14"
                                       TextColor="#777777" />

                                <Label Grid.Row="4"
                                       Grid.Column="0"
                                       Text="{Binding TrackName, StringFormat='Track: {0}'}"
                                       FontSize="14"
                                       TextColor="#777777" />
                                <Label Grid.Row="5"
                                       Grid.Column="0"
                                       Text="{Binding IsDone, StringFormat='Completed: {0}'}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#27AE60" />

                                <Frame Grid.Row="0"
                                       Grid.RowSpan="2"
                                       Grid.Column="1"
                                       Padding="10,5"
                                       CornerRadius="12"
                                       BackgroundColor="#EAF2FF"
                                       HasShadow="False"
                                       VerticalOptions="Center">

                                    <Label Text="{Binding TripId, StringFormat='ID: {0}'}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#4A90E2" />

                                </Frame>

                                <Button Grid.Row="6"
                                        Grid.Column="0"
                                        Text="Edit"
                                        Clicked="OnEditClicked"
                                        BackgroundColor="#3498DB"
                                        TextColor="White"
                                        HeightRequest="45"
                                        CornerRadius="12"
                                        WidthRequest="220" />

                                <Button Grid.Row="6"
                                        Grid.Column="1"
                                        Text="Delete"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TripViewModel}}, Path=DeleteTripCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#E74C3C"
                                        TextColor="White"
                                        HeightRequest="45"
                                        CornerRadius="12"
                                        WidthRequest="220" />

                            </Grid>

                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>